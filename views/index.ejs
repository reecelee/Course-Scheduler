<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Holokai Planner</title>
    <link rel="stylesheet" href="public/style.css" />
  </head>
  <body>
    <!-- New Header Section -->
    <header class="top-header">
      <div class="top-header-content">
        <h2 class="site-logo">My University Planner</h2>
        <nav class="top-nav">
          <a href="/" class="nav-link active">Full Schedule</a>
          <a href="/single" class="nav-link">Single Scheduler</a>
        </nav>
      </div>
    </header>
    <!-- End of New Header Section -->

    <div class="background-image">
      <!-- Start of the image container -->
      <div class="header-image-container">
        <img
          src="assets/Single.png"
          alt="University Campus"
          class="header-image"
        />
      </div>
      <!-- End of the image container -->

      <!-- Start of the container -->
      <div class="container">
        <header class="floating-bar">
          <!-- First Row -->
          <!-- Majors -->
          <div class="input-group">
            <label for="major">Major:</label>
            <select id="major">
              <%- include('partials/majors.ejs') %>
            </select>
          </div>

          <!-- Minor 1 -->

          <div class="input-group">
            <label for="minor1">Minor 1:</label>
            <select id="minor1">
              <%- include('partials/minors.ejs') %>
            </select>
          </div>

          <!-- Minor 2 -->

          <div class="input-group">
            <label for="minor2">Minor 2:</label>
            <select id="minor2">
              <%- include('partials/minors.ejs') %>
            </select>
          </div>

          <div class="input-group">
            <label for="english-level">English Level:</label>
            <select id="english-level">
              <option value="fluent">Fluent</option>
              <option value="academic-english-2">Academic English 2</option>
              <option value="academic-english-1">Academic English 1</option>
            </select>
          </div>

          <!-- Second Row -->
          <%- include('partials/header.ejs') %>
          <!-- Generate Schedule button -->
          <button id="calculate-schedule">Generate Schedule</button>
        </header>

        <!-- Schedule Container (Initially Hidden) -->
        <div id="schedule-container" class="hidden">
          <!-- Summary Information -->
          <div id="summary" class="summary-box">
            <div class="summary-item animated-box" id="total-credits-box">
              <p>Total Credits Taken</p>
              <h2 id="total-credits">0</h2>
            </div>
            <div class="summary-item animated-box" id="graduation-date-box">
              <p>Graduation Date</p>
              <h2 id="graduation-date">TBD</h2>
            </div>
            <div class="summary-item animated-box" id="electives-needed-box">
              <p>Elective Credits Needed</p>
              <h2 id="electives-needed">0</h2>
            </div>
          </div>

          <!-- Schedule Grid -->
          <div id="schedule">
            <!-- Semester boxes populated by JavaScript -->
          </div>
        </div>
      </div>
      <!-- End of the container -->
    </div>

    <script src="script.js"></script>
  </body>
</html>
